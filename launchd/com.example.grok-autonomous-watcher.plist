<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.example.grok-autonomous-watcher</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/python3</string>
    <string>/Users/YOUR_USER/path/to/grok-go-organism-share/scripts/grok-autonomous-log-watcher.py</string>
  </array>
  <key>WorkingDirectory</key>
  <string>/Users/YOUR_USER/path/to/grok-go-organism-share</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/Users/YOUR_USER/.grok/autonomous-watcher.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/YOUR_USER/.grok/autonomous-watcher.err.log</string>
</dict>
</plist>
