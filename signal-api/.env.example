# Copy to .env — never commit .env to repo
# Store real values in 1Password

# Stripe (create account at stripe.com, get keys from dashboard)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_TIER1=price_...   # $99/mo — create in Stripe Products
STRIPE_PRICE_TIER2=price_...   # $499/mo
STRIPE_PRICE_TIER3=price_...   # $2499/mo

# Admin token (make this a strong random string — store in 1Password)
ADMIN_TOKEN=change-me-to-something-strong

# SoMaCoSF integration (Sam provides this)
SOMACOSF_URL=https://somacosf.com
SOMACOSF_TOKEN=

# Local model (Ollama)
LOCAL_MODEL_NAME=qwen3:4b

# Optional: email delivery for API keys (Resend or SendGrid)
RESEND_API_KEY=
FROM_EMAIL=signal@yourdomain.com
